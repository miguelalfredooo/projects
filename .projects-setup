#!/bin/bash
# Projects Monorepo Setup & Workflow Guide
# Location: /Users/blackmachete/projects/.projects-setup
# Run: source /Users/blackmachete/projects/.projects-setup

# =============================================================================
# QUICK START
# =============================================================================
# Add this to ~/.zshrc or ~/.bashrc:
#   source /Users/blackmachete/projects/.projects-setup
#
# Then use:
#   bb                  # Jump to bulletin-board
#   pb                  # Jump to patched-editorial (parent)
#   projects-status     # Check all repos
#   projects-update     # Pull latest from all projects

# =============================================================================
# ALIASES
# =============================================================================

alias bb='cd /Users/blackmachete/projects/patched-editorial/projects/bulletin-board'
alias pb='cd /Users/blackmachete/projects/patched-editorial'
alias projects='cd /Users/blackmachete/projects'
alias oc-artifacts='cd /Users/blackmachete/projects/openclaw-artifacts'
alias oc-mission='cd /Users/blackmachete/projects/openclaw-mission-control'
alias brief='cd /Users/blackmachete/projects/the-brief'

# =============================================================================
# FUNCTIONS
# =============================================================================

# Show all projects and their status
projects-status() {
  echo "=== Projects Monorepo Status ==="
  echo ""

  cd /Users/blackmachete/projects

  echo "📍 Main Monorepo:"
  git status --short

  echo ""
  echo "📦 Subprojects:"
  for dir in patched-editorial openclaw-artifacts openclaw-mission-control; do
    if [ -d "$dir/.git" ]; then
      echo ""
      echo "  $dir:"
      cd "$dir"
      git status --short || echo "    (not a git repo)"
      cd ..
    fi
  done

  echo ""
  echo "💡 Tip: Use 'bb' to jump to bulletin-board"
}

# Pull latest from all projects
projects-update() {
  echo "=== Updating all projects ==="
  cd /Users/blackmachete/projects

  echo "Updating main monorepo..."
  git pull origin main

  echo ""
  echo "Updating submodules..."
  git submodule foreach git pull origin main

  echo ""
  echo "✅ All projects updated"
}

# Commit and push from current project
projects-sync() {
  local current_dir=$(pwd)
  local project_root="/Users/blackmachete/projects"

  # Find which project we're in
  if [[ "$current_dir" == *"patched-editorial"* ]]; then
    cd "$project_root"
    echo "Syncing patched-editorial..."
    git add patched-editorial
    git commit -m "Update patched-editorial submodule"
    git push origin main
    cd "$current_dir"
  elif [[ "$current_dir" == *"openclaw-artifacts"* ]]; then
    cd "$project_root"
    echo "Syncing openclaw-artifacts..."
    git add openclaw-artifacts
    git commit -m "Update openclaw-artifacts submodule"
    git push origin main
    cd "$current_dir"
  elif [[ "$current_dir" == *"openclaw-mission-control"* ]]; then
    cd "$project_root"
    echo "Syncing openclaw-mission-control..."
    git add openclaw-mission-control
    git commit -m "Update openclaw-mission-control submodule"
    git push origin main
    cd "$current_dir"
  else
    echo "❌ Not in a recognized project directory"
    echo "Current: $current_dir"
  fi
}

